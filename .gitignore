# ─────────────────────────────────────────────────────────────────────────────
# .gitignore
#
# Keep these files/folders from GitHub.
# ─────────────────────────────────────────────────────────────────────────────

# log files generated when something crashes
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# all installed packages - cloning the repo and running npm install will regenerate this folder
node_modules

# built output folders - regenerated by npm run build
dist
dist-ssr

# local environment files 
*.local

# VS Code workspace settings - kept out so vscode preferences don't merge
# the settings.json for Tailwind is excluded from this rule below
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# other editor and OS junk files
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Vercel deployment config - contains project ID
.vercel